---
interface Props {

  role: string;
  company: string;
  period: string;
  description: string;

}

const { role, company, period, description } = Astro.props;
---

<div class="timeline-item">

  <div class="header">

    <h3>
      {role}
    </h3>

    <span class="badge">
      {period}
    </span>

  </div>

  <span class="company">
    {company}
  </span>

  <p>
    {description}
  </p>

</div>

<style>

.timeline-item{

  padding:10px;

  border-radius:14px;

  border:1px solid rgba(56,189,248,0.15);

  background:rgba(2,6,23,0.7);

  margin-bottom:20px;

}

.header{

  display:flex;
  justify-content:space-between;
  align-items:center;

}

h3{

  font-size:20px;

}

.company{

  color:#38bdf8;

  font-size:14px;

}

.badge{

  font-size:12px;

  background:rgba(148,163,184,0.15);

  padding:6px 10px;

  border-radius:6px;

}

p{

  margin-top:10px;

  color:#94a3b8;

}

.header{

  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:10px;

}

/* mobile */
@media (max-width:600px){

  .header{

    flex-direction:column;
    align-items:flex-start;
    gap:6px;

  }

  h3{
    font-size:18px;
  }

  .badge{

    font-size:11px;

  }

}
</style>