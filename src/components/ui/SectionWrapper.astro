---
interface Props {
  id: string;
}

const { id } = Astro.props;
---

<section id={id} class="section">

  <slot />

</section>

<style>

.section{
  min-height:100vh;

  display:flex;
  justify-content:center;
  align-items:center;

  scroll-snap-align:start;
}

/* let content taller than one viewport (stacked mobile layouts) breathe instead of overlapping the next section */
@media (max-width:900px){

  .section{

    padding:100px 0;

  }

}

</style>