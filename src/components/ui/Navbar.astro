---

const menu = [
  { id: "intro", label: "Intro" },
  { id: "about", label: "About" },
  { id: "experience", label: "Experience" },
  { id: "projects", label: "Projects" },
];

---

<nav class="navbar">

  {menu.map(item => (

    <a
      href={`#${item.id}`}
      class="nav-item"
      data-section={item.id}
    >
      {item.label}
    </a>

  ))}

</nav>

<style>

.navbar{
  position:fixed;
  top:20px;
  left:50%;
  transform:translateX(-50%);
  display:flex;
  gap:20px;
  padding:12px 24px;
  border-radius:999px;

  background:rgba(0,0,0,0.7);
  backdrop-filter:blur(12px);

  z-index:1000;
}

.nav-item{
  color:#9ca3af;
  text-decoration:none;
  font-size:14px;
  transition:0.3s;
}

.nav-item.active{
  color:#22c55e;
}

</style>