---
interface Props {
  title:string;
  description:string;
  image:string;
  tags:string[];
  id:string;
}

const { title, description, image, tags, id } = Astro.props;
---

<div 
  class="project-card"
  data-project-id={id}
>

  <img src={image} alt={title} />

  <div class="content">

    <h3>{title}</h3>

    <p>{description}</p>

    <div class="tags">

      {tags.map(tag => (

        <span>#{tag}</span>

      ))}

    </div>

  </div>

</div>

<style>

.project-card{

  background:rgba(2,6,23,0.7);

  border-radius:18px;

  border:1px solid rgba(56,189,248,0.15);

  overflow:hidden;

  cursor:pointer;

  transition:.25s;

  height:100%;

  display:flex;

  flex-direction:column;

}

.project-card:hover{

  transform:translateY(-6px);

  border-color:#38bdf8;

}

.project-card img{

  width:100%;

  height:160px;

  object-fit:cover;

}

.content{

  padding:8px;

  display:flex;

  flex-direction:column;

  gap:5px;

  flex:1;

}

.content h3{

  font-size:18px;

}

.content p{

  font-size:13px;

  line-height:1.45;

  color:#94a3b8;

}

.tags{

  margin-top:auto;

  display:flex;

  gap:8px;

  flex-wrap:wrap;

}

.tags span{

  font-size:12px;

  padding:4px 8px;

  border-radius:6px;

  background:rgba(148,163,184,0.15);

}

/* mobile */
@media (max-width:600px){

  .project-card img{

    height:150px;

  }

}

</style>