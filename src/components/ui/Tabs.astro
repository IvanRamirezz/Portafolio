---
interface Tab {
  id: string;
  label: string;
}

interface Props {
  tabs: Tab[];
}

const { tabs } = Astro.props;
---

<div class="tabs" data-tabs>

  {tabs.map((tab, index) => (

    <button
      class={`tab ${index === 0 ? "active" : ""}`}
      data-tab-button={tab.id}
    >

      {tab.label}

    </button>

  ))}

</div>


<script is:inline>

document.addEventListener("DOMContentLoaded", () => {

  const allTabs = document.querySelectorAll("[data-tabs]");

  allTabs.forEach(tabContainer => {

    const buttons = tabContainer.querySelectorAll("[data-tab-button]");

    const wrapper = tabContainer.parentElement;

    const contents = wrapper.querySelectorAll("[data-content]");

    buttons.forEach(button => {

      button.addEventListener("click", () => {

        const id = button.dataset.tabButton;

        /* activar botón */

        buttons.forEach(btn => btn.classList.remove("active"));

        button.classList.add("active");

        /* cambiar contenido */

        contents.forEach(content => {

          content.classList.remove("active");

          if(content.dataset.content === id){

            content.classList.add("active");

          }

        });

      });

    });

  });

});

</script>


<style>

.tabs{

  display:flex;
  gap:12px;

  margin-bottom:20px;

}

.tab{

  padding:8px 16px;

  border-radius:10px;

  border:1px solid rgba(148,163,184,0.2);

  background:transparent;

  color:#94a3b8;

  cursor:pointer;

  transition:0.2s;

}

.tab:hover{

  border-color:#38bdf8;

}

.tab.active{

  color:#22c55e;

  border-color:#22c55e;

  background:rgba(34,197,94,0.08);

}

.tabs{

  display:flex;
  gap:12px;
  margin-bottom:20px;
  flex-wrap:wrap;

}

@media (max-width:600px){

  .tabs{

    width:100%;

  }

  .tab{

    flex:1;
    text-align:center;

  }

}
</style>