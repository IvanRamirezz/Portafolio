---
import SectionWrapper from "../ui/SectionWrapper.astro";
import Card from "../ui/Card.astro";
---

<SectionWrapper id="about">

  <Card>

    <div class="about-grid">

      <div>

        <span class="eyebrow">
          02 / MINDSET
        </span>

        <h2>

          Thinking in <span>Systems</span>.
          Not in Syntax.

        </h2>

        <p>

          I am a tech enthusiast specializing in Python web development,
          data engineering, and AWS cloud technologies.

        </p>

        <p>

          My expertise lies in designing and optimizing robust
          data pipelines, crafting Python backends, and implementing
          efficient automation scripts.

        </p>

        <p>

          I excel in solving intricate data problems by delivering
          efficient solutions with clean, easy-to-maintain code.

        </p>

      </div>

      <div class="photo-container">

            <img
            src={`${import.meta.env.BASE_URL}images/ivan.jpeg`}
            alt="Ivan Ramirez"
            />

      </div>

    </div>

  </Card>

</SectionWrapper>

<style>

.about-grid{

  display:grid;

  grid-template-columns:

  1.2fr 0.8fr;

  gap:40px;

  align-items:center;

}

.eyebrow{

  font-size:12px;

  letter-spacing:2px;

  color:#38bdf8;

}

h2{

  font-size:40px;

  margin:10px 0 20px;

}

h2 span{

  color:#38bdf8;

}

p{

  color:#94a3b8;

  margin-bottom:14px;

  line-height:1.7;

}

.photo-container{

  display:flex;

  justify-content:center;

}

.photo-container img{

  width:200px;
  height:200px;

  object-fit:cover;

  border-radius:50%;

  padding:6px;

  background:linear-gradient(
    45deg,
    #38bdf8,
    #22c55e
  );

}

@media (max-width:900px){

  .about-grid{

    grid-template-columns:1fr;

    text-align:center;

  }

}

</style>