---
import SectionWrapper from "../ui/SectionWrapper.astro";
import Card from "../ui/Card.astro";
import Tabs from "../ui/Tabs.astro";
import TimelineItem from "../ui/TimelineItem.astro";
import CertificationItem from "../ui/CertificationItem.astro";
---

<SectionWrapper id="experience">

  <Card>

    <div class="experience-grid">

      <!-- LEFT COLUMN -->

      <div>

        <span class="eyebrow">
          03 / PROCESSOR
        </span>

        <h2>
            Experiencia <span>real</span>.
            Resultados comprobados.
        </h2>

        <p class="subtitle">
          Experiencia en pruebas de software, validación de datos y desarrollo web.
        </p>

        <hr />

        <span class="eyebrow">
          CURSOS
        </span>

        <CertificationItem
          title="Git y Control de Versiones"
          org="UDEMY"
          year="2025"
        />

        <CertificationItem
          title="Oracle AI Foundations Associate"
          org="Cisco"
          year="2025"
        />

        <CertificationItem
          title="Introducción al IoT y
                 Transformación Digital"
          org="Cisco"
          year="2025"
        />

      </div>

      <!-- RIGHT COLUMN -->

      <div>

        <Tabs
          tabs={[
            { id: "experience", label: "Experiencia" },
            { id: "education", label: "Educación" }
          ]}
        />

        <!-- EXPERIENCE -->

        <div data-content="experience" class="tab-content active">

          <TimelineItem
            role="Test Developer Intern"
            company="IBM"
            period="2025 Junio - 2026 Febrero"
            description="Ejecución de pruebas funcionales y de regresión para app web y móvil.
            Diseño de casos de prueba, seguimiento de defectos y validación de reglas de negocio 
            utilizando Jira, ALM y ServiceNow."
          />

            <TimelineItem
            role="Web Development Intern"
            company="Actipulse"
            period="2024 Noviembre - 2025 Mayo"
            description={`Desarrollo de interfaces web responsivas con HTML, CSS y Tailwind.
            Integración de API y automatización de validación de datos mediante Python y Postman.`}
            />

        </div>

        <!-- EDUCATION -->

        <div data-content="education" class="tab-content">

          <TimelineItem
            role="Ingeniería Telemática"
            company="UPIITA - IPN"
            period="2021 - Present"
            description="Formación en redes, desarrollo de software y análisis de datos.
            Desarrollo de laboratorio en realidad virtual para medición de dispersión y 
            atenuación en fibras ópticas."
          />

        </div>

      </div>

    </div>

  </Card>

</SectionWrapper>

<style>

.experience-grid{

  display:grid;

  grid-template-columns: 1fr 1.2fr;

  gap:40px;

}

.subtitle{

  color:#94a3b8;

  margin:10px 0 20px;

}

.tab-content{

  display:none;

}

.tab-content.active{

  display:block;

}

hr{

  border:none;

  border-top:1px solid rgba(148,163,184,0.2);

  margin:25px 0;

}

h2 span{

  color:#38bdf8;

}

.tab-content{
  display:none;
}

.tab-content.active{
  display:block;
}

/* tablet */
@media (max-width: 900px){

  .experience-grid{

    grid-template-columns: 1fr;
    gap:30px;

  }

}

/* mobile */
@media (max-width: 600px){

  h2{
    font-size:26px;
    line-height:1.2;
  }

  .subtitle{
    font-size:14px;
  }

}

</style>